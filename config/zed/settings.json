// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "base_keymap": "VSCode",
  "cli_default_open_behavior": "existing_window",
  "language_models": {
    // "bedrock": {
    //   "authentication_method": "named_profile",
    //   "region": "ap-southeast-1",
    //   "profile": "prod",
    // },
  },
  "agent_servers": {
    "pi-acp": {
      "type": "registry"
    },
    "pi": {
      "type": "custom",
      "command": "node",
      "args": ["/Users/prayagmatic/dev/pi-extensions/pi-acp/dist/index.js"],
      "env": {}
    },
    "opencode": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "factory-droid": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    },
    "amp-acp": {
      "type": "registry"
    }
  },
  "toolbar": {
    "code_actions": true
  },
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "diff_view_style": "unified",
  "proxy": "",
  "current_line_highlight": "all",
  "multi_cursor_modifier": "cmd_or_ctrl",
  "buffer_line_height": {
    "custom": 1.350000023841858
  },
  "session": {
    "trust_all_worktrees": true
  },
  "when_closing_with_no_tabs": "platform_default",
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "show_count_badge": false,
    "tree_view": true,
    "dock": "right"
  },
  "double_click_in_multibuffer": "open",
  "which_key": {
    "enabled": true
  },
  "project_panel": {
    "dock": "right",
    "bold_folder_labels": true
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
      "delay_ms": 100
    }
  },
  "audio": {
    "experimental.auto_microphone_volume": true,
    "experimental.rodio_audio": true
  },
  "calls": {
    "share_on_join": true,
    "mute_on_join": true
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_menus": false
  },
  "search": {
    "center_on_match": true,
    "regex": true
  },
  "lsp_document_colors": "inlay",
  "indent_guides": {
    "background_coloring": "disabled",
    "coloring": "fixed"
  },
  "tab_size": 2,
  "gutter": {
    "min_line_number_digits": 2
  },
  "relative_line_numbers": "enabled",
  "show_signature_help_after_edits": true,
  "agent_buffer_font_size": 12.0,
  "confirm_quit": true,
  "terminal": {
    "font_size": 13.0,
    "minimum_contrast": 0,
    "copy_on_select": true,
    "option_as_meta": true,
    "toolbar": {
      "breadcrumbs": false
    }
  },
